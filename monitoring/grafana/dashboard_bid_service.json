{
  "uid": "bid-service-dashboard",
  "title": "Bid Service - Metrics",
  "tags": ["auction","service","bid"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "p99 Request Latency by Route (5m)",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, method, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Request Latency by Route (5m)",
      "id": 2,
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate (req/s) by Route",
      "id": 3,
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum by (method, route) (rate(http_requests_total[1m]))", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Error Rate by Route (req/s)",
      "id": 4,
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum by (route) (rate(http_requests_total{code_class=\"5xx\"}[5m]))", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka Consumer Lag by Group",
      "id": 5,
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum by (consumergroup) (kafka_consumergroup_lag_sum)", "refId": "A"}
      ],
      "description": "Uses kafka-exporter consumer lag metrics. Requires at least one active consumer group."
    },
    {
      "type": "timeseries",
      "title": "Redis Memory Used",
      "id": 6,
      "gridPos": {"x": 12, "y": 12, "w": 6, "h": 6},
      "targets": [
        {"expr": "redis_memory_used_bytes", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Postgres Exporter Up",
      "id": 7,
      "gridPos": {"x": 18, "y": 12, "w": 6, "h": 6},
      "targets": [
        {"expr": "up{job=\"postgres-exporter\"}", "refId": "A"}
      ],
      "options": {"orientation": "auto"}
    }
    ,
    {
      "type": "timeseries",
      "title": "Go Bid API p99 (overall, 5m)",
      "id": 8,
      "gridPos": {"x": 0, "y": 18, "w": 12, "h": 6},
      "targets": [
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Auction Price Hot-Key Throughput",
      "id": 9,
      "gridPos": {"x": 12, "y": 18, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "sum(rate(redis_auction_price_access_total[1m]))",
          "refId": "A"
        }
      ],
      "description": "App-side counter for the auction price Redis hot-key path. This is the exact throughput for the key family used by bid processing."
    },
    {
      "type": "timeseries",
      "title": "Redis CPU (user+system) rate",
      "id": 10,
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 6},
      "targets": [
        {"expr": "rate(redis_cpu_sys_seconds_total[1m]) + rate(redis_cpu_user_seconds_total[1m])", "refId": "A"}
      ],
      "description": "Sum of Redis process CPU user+system. Adjust metric names if your exporter differs."
    },
    {
      "type": "timeseries",
      "title": "Kafka Consumer Lag by Topic",
      "id": 11,
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum by (topic) (kafka_consumergroup_lag_sum)", "refId": "A"}
      ],
      "description": "Shows total lag per topic across consumer groups. Uses kafka-exporter lag metrics."
    },
    {
      "type": "timeseries",
      "title": "Postgres Connections (active)",
      "id": 12,
      "gridPos": {"x": 0, "y": 30, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum by (datname) (pg_stat_activity_count{state=\"active\"})", "refId": "A"}
      ],
      "description": "Active DB connections by database. Uses postgres-exporter stat_activity metrics."
    },
    {
      "type": "timeseries",
      "title": "Postgres Transactions/sec",
      "id": 13,
      "gridPos": {"x": 12, "y": 30, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum by (datname) (rate(pg_stat_database_xact_commit[1m]) + rate(pg_stat_database_xact_rollback[1m]))", "refId": "A"}
      ],
      "description": "Commits plus rollbacks per second by database. Uses postgres-exporter stat_database metrics."
    }
  ],
  "annotations": {"list": []},
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"}
}
